{
  "plan": {
    "name": "invoice-parse",
    "default_target": "dev-bootstrap",
    "output_dir": "infra",
    "entries": {
      "processing": {
        "name": "processing",
        "path": "services/processing",
        "dockerfile": "services/processing/Dockerfile",
        "triggers": [
          {
            "kind": "queue",
            "queue": {
              "from": "invoice_queue"
            }
          }
        ],
        "uses": [
          "invoice_queue",
          "invoice_db",
          "invoice_blobs",
          "gemini_key"
        ]
      }
    },
    "seams": {
      "LLMExtraction": {
        "name": "LLMExtraction",
        "path": "services/processing",
        "dockerfile": "services/processing/Dockerfile",
        "uses": [
          "gemini_key"
        ],
        "impl": "invoice_processing.extraction:GeminiExtractor",
        "service_name": "llm-extractor",
        "env_file": "../.env"
      }
    },
    "resources": {
      "invoice_blobs": {
        "name": "invoice_blobs",
        "type": "bucket",
        "composition": "oss-local"
      },
      "invoice_db": {
        "name": "invoice_db",
        "type": "db.sql",
        "composition": "oss-local"
      },
      "invoice_queue": {
        "name": "invoice_queue",
        "type": "queue",
        "composition": "oss-local"
      }
    },
    "secrets": {
      "gemini_key": {
        "name": "gemini_key",
        "from": "env",
        "path": "GEMINI_API_KEY"
      }
    },
    "targets": {
      "dev-bootstrap": {
        "name": "dev-bootstrap",
        "runtime": "docker-compose",
        "default_composition": "oss-local",
        "entries": {
          "processing": "container"
        },
        "seams": {
          "LLMExtraction": "container"
        }
      },
      "dev-inproc": {
        "name": "dev-inproc",
        "runtime": "docker-compose",
        "default_composition": "oss-local",
        "entries": {
          "processing": "container"
        }
      },
      "dev-rabbitmq-flip": {
        "name": "dev-rabbitmq-flip",
        "runtime": "docker-compose",
        "default_composition": "oss-local",
        "entries": {
          "processing": "container"
        },
        "seams": {
          "LLMExtraction": "container"
        },
        "composition": {
          "invoice_queue": {
            "mode": "oss-local",
            "kind": "rabbitmq"
          }
        }
      }
    }
  },
  "target": "dev-rabbitmq-flip",
  "env_vars": {
    "processing": {
      "CARAVAN_RPC_PEERS": "{\"LLMExtraction\":{\"mode\":\"http\",\"url\":\"http://llm-extractor:8080\"}}"
    }
  },
  "peers_json": "{\"LLMExtraction\":{\"mode\":\"http\",\"url\":\"http://llm-extractor:8080\"}}",
  "peer_tables": {
    "processing": {
      "LLMExtraction": {
        "mode": "http",
        "url": "http://llm-extractor:8080"
      }
    }
  },
  "resolved_resources": {
    "invoice_blobs": {
      "name": "invoice_blobs",
      "type": "bucket",
      "composition": "oss-local",
      "variant": "minio"
    },
    "invoice_db": {
      "name": "invoice_db",
      "type": "db.sql",
      "composition": "oss-local",
      "variant": "postgres"
    },
    "invoice_queue": {
      "name": "invoice_queue",
      "type": "queue",
      "composition": "oss-local",
      "variant": "rabbitmq"
    }
  },
  "resource_env_vars": {
    "processing": {
      "AWS_ACCESS_KEY_ID": "minioadmin",
      "AWS_REGION": "us-east-1",
      "AWS_SECRET_ACCESS_KEY": "minioadmin",
      "CARAVAN_BLOB_BACKEND": "local-fs",
      "DATABASE_URL": "postgresql://caravan:caravan@postgres:5432/caravan",
      "QUEUE_URL": "amqp://guest:guest@rabbitmq:5672",
      "S3_ENDPOINT_URL": "http://minio:9000"
    }
  }
}
